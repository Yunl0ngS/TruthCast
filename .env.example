# ============================================================
# TruthCast 环境配置示例
# 复制此文件为 .env 并填写实际值
# ============================================================

# ------------------------------------------------------------
# 0. 安全配置（CORS / 认证 / 限流 / SSRF 防护）
# ------------------------------------------------------------
# CORS 白名单（逗号分隔，留空默认允许 localhost:3000）
TRUTHCAST_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# API Key 认证（留空则关闭认证，适合本地开发）
TRUTHCAST_API_KEY=

# IP 限流：每分钟每 IP 最大请求数（0 = 不限流）
TRUTHCAST_RATE_LIMIT_RPM=60

# SSRF 防护：是否阻止对私有/内部 IP 的请求（true/false）
TRUTHCAST_SSRF_BLOCK_PRIVATE=true

# ------------------------------------------------------------
# 1. 基础配置
# ------------------------------------------------------------
APP_NAME=TruthCast MVP
APP_ENV=dev
LOG_LEVEL=INFO

# 前端 API 基础地址（web-next / web）
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# ------------------------------------------------------------
# 2. LLM 基础配置（全局）
# ------------------------------------------------------------
TRUTHCAST_LLM_ENABLED=false
TRUTHCAST_LLM_BASE_URL=https://api.openai.com/v1
TRUTHCAST_LLM_MODEL=gpt-4o-mini
TRUTHCAST_LLM_API_KEY=
# 全局 LLM 超时（秒）
TRUTHCAST_LLM_TIMEOUT=60
# 通用 LLM 调试日志开关
TRUTHCAST_DEBUG_LLM=true

# ------------------------------------------------------------
# 3. Claim 抽取配置
# ------------------------------------------------------------
# 主张抽取模式（default / llm_first/ claimify 等，未识别值自动回退 default）
TRUTHCAST_CLAIM_METHOD=default
# Claim 抽取专用模型（留空使用全局模型）
TRUTHCAST_EXTRACTION_LLM_MODEL=
TRUTHCAST_CLAIM_MAX_ITEMS=8
TRUTHCAST_CLAIM_MIN_SCORE=0.25

# ------------------------------------------------------------
# 4. 风险快照配置
# ------------------------------------------------------------
TRUTHCAST_RISK_LLM_ENABLED=false
TRUTHCAST_RISK_LLM_MODEL=
TRUTHCAST_DEBUG_RISK_SNAPSHOT=true

# ------------------------------------------------------------
# 5. 文本复杂度分析配置
# ------------------------------------------------------------
TRUTHCAST_COMPLEXITY_LLM_ENABLED=false
TRUTHCAST_COMPLEXITY_LLM_MODEL=
TRUTHCAST_DEBUG_COMPLEXITY=false

# ------------------------------------------------------------
# 6. 证据对齐配置
# ------------------------------------------------------------
TRUTHCAST_ALIGNMENT_LLM_ENABLED=false
TRUTHCAST_ALIGNMENT_LLM_MODEL=
TRUTHCAST_DEBUG_ALIGNMENT=true

# ------------------------------------------------------------
# 7. 联网检索配置
# ------------------------------------------------------------
# 通用搜索 API Key（某些 Provider 会读取该值）
TRUTHCAST_WEB_SEARCH_API_KEY=
# 启用联网检索
TRUTHCAST_WEB_RETRIEVAL_ENABLED=true
# 每条主张最大检索数量
TRUTHCAST_WEB_RETRIEVAL_TOPK=10
# 请求超时（秒）
TRUTHCAST_WEB_RETRIEVAL_TIMEOUT_SEC=8
# Debug 日志
TRUTHCAST_DEBUG_WEB_RETRIEVAL=true

# === 搜索 Provider 选择 ===
# 可选值: baidu | bocha | searxng | tavily | serpapi
TRUTHCAST_WEB_SEARCH_PROVIDER=bocha

# === 博查搜索 (推荐国内使用) ===
# 注册地址: https://open.bochaai.com/
TRUTHCAST_BOCHA_API_KEY=
TRUTHCAST_BOCHA_ENDPOINT=https://api.bochaai.com/v1/web-search
# 时间过滤: noLimit | oneDay | oneWeek | oneMonth | oneYear
TRUTHCAST_BOCHA_FRESHNESS=oneYear
# 是否返回摘要
TRUTHCAST_BOCHA_SUMMARY=true

# === SearXNG (开源元搜索，免费) ===
# 公开实例: searx.be | search.bus-hit.me | northboot.xyz
TRUTHCAST_SEARXNG_ENDPOINT=https://searx.be/search
# 聚合引擎（逗号分隔）
TRUTHCAST_SEARXNG_ENGINES=google,bing,duckduckgo
# 可选分类: general | images | news | videos
TRUTHCAST_SEARXNG_CATEGORIES=
TRUTHCAST_SEARXNG_LANGUAGE=zh-CN

# === 百度搜索 (国内) ===
TRUTHCAST_BAIDU_API_KEY=
TRUTHCAST_BAIDU_ENDPOINT=https://api.qnaigc.com/v1/search/web
# 时间过滤: day | week | month | year
TRUTHCAST_BAIDU_TIME_FILTER=year
# 站点过滤（逗号分隔）
TRUTHCAST_BAIDU_SITE_FILTER=news.cctv.com,www.xinhuanet.com

# === Tavily (需代理) ===
TRUTHCAST_TAVILY_API_KEY=
TRUTHCAST_TAVILY_ENDPOINT=https://api.tavily.com/search

# === SerpAPI (需代理) ===
TRUTHCAST_SERPAPI_API_KEY=
TRUTHCAST_SERPAPI_ENDPOINT=https://serpapi.com/search.json

# === 域名过滤（通用） ===
# 仅允许指定域名的结果（留空不限制）
TRUTHCAST_WEB_ALLOWED_DOMAINS=

# ------------------------------------------------------------
# 8. 证据摘要配置
# ------------------------------------------------------------
TRUTHCAST_EVIDENCE_SUMMARY_ENABLED=false
TRUTHCAST_EVIDENCE_SUMMARY_MAX_ITEMS=3
TRUTHCAST_EVIDENCE_SUMMARY_INPUT_LIMIT=10
TRUTHCAST_EVIDENCE_SUMMARY_LLM_MODEL=
TRUTHCAST_DEBUG_EVIDENCE_SUMMARY=true

# ------------------------------------------------------------
# 9. 并行处理配置
# ------------------------------------------------------------
TRUTHCAST_CLAIM_PARALLEL_WORKERS=3
TRUTHCAST_ALIGN_PARALLEL_WORKERS=4

# ------------------------------------------------------------
# 10. 舆情预演配置
# ------------------------------------------------------------
TRUTHCAST_SIMULATION_LLM_ENABLED=false
TRUTHCAST_SIMULATION_LLM_MODEL=gpt-4o-mini
TRUTHCAST_SIMULATION_MAX_NARRATIVES=4
TRUTHCAST_SIMULATION_TIMEOUT_SEC=45
TRUTHCAST_SIMULATION_MAX_RETRIES=2
TRUTHCAST_SIMULATION_RETRY_DELAY=2
TRUTHCAST_DEBUG_SIMULATION=true

# ------------------------------------------------------------
# 11. 报告生成配置
# ------------------------------------------------------------
# 启用 LLM 驱动的报告生成
TRUTHCAST_REPORT_LLM_ENABLED=false
# 独立模型配置（留空使用全局）
TRUTHCAST_REPORT_LLM_MODEL=
# 请求超时（秒）
TRUTHCAST_REPORT_TIMEOUT_SEC=30
# 报告时间语境时区（用于时间错位/预测性描述判断）
TRUTHCAST_REPORT_TZ=Asia/Hong_Kong
# 主张排序权重衰减系数（0-2，越大越强调前排主张）
TRUTHCAST_CLAIM_RANK_ALPHA=0.25
# 报告计分 TopK（0=不启用；>0 时仅前 K 条主张保持全权重）
TRUTHCAST_REPORT_TOPK=0
# 超出 TopK 的主张计分折扣（0-1）
TRUTHCAST_REPORT_NON_TOPK_FACTOR=0.5
# 综合报告分数分解日志（留空则跟随 TRUTHCAST_DEBUG_REPORT）
TRUTHCAST_REPORT_SCORE_BREAKDOWN_ENABLED=
# Debug 日志
TRUTHCAST_DEBUG_REPORT=true

# ------------------------------------------------------------
# 12. 性能优化配置
# ------------------------------------------------------------
# URL 抽取主链路开关（一期默认启用本地抽取）
TRUTHCAST_URL_EXTRACT_ENABLED=true
# 正文抽取主模型
TRUTHCAST_URL_EXTRACT_PRIMARY=readability
# 正文抽取补路
TRUTHCAST_URL_EXTRACT_SECONDARY=trafilatura
# 低置信度时是否启用渲染页 fallback
TRUTHCAST_URL_EXTRACT_RENDER_FALLBACK=true
# 主体正文最小字符数
TRUTHCAST_URL_EXTRACT_MIN_CONTENT_LEN=150
# 主体正文最小段落数
TRUTHCAST_URL_EXTRACT_MIN_PARAGRAPHS=2
# 链接密度阈值（高于该值视为高噪声）
TRUTHCAST_URL_EXTRACT_MAX_LINK_DENSITY=0.35
# 中文噪声词（逗号分隔）
TRUTHCAST_URL_EXTRACT_NOISE_TERMS=相关阅读,推荐阅读,延伸阅读,点击查看,责任编辑,来源：,上一篇,下一篇,广告,免责声明
# URL 抽取调试日志
TRUTHCAST_URL_EXTRACT_DEBUG=true
# 渲染 fallback 超时（秒）
TRUTHCAST_URL_RENDER_TIMEOUT_SEC=20
# 渲染等待策略（load / domcontentloaded / networkidle）
TRUTHCAST_URL_RENDER_WAIT_UNTIL=networkidle
# URL 抽取 LLM 增强开关
TRUTHCAST_URL_EXTRACT_LLM_ENABLED=false
# URL 抽取 LLM 模式（postprocess / rescue / both）
TRUTHCAST_URL_EXTRACT_LLM_MODE=postprocess
# URL 抽取专用模型（留空则使用全局模型）
TRUTHCAST_URL_EXTRACT_LLM_MODEL=
# URL 抽取 LLM 超时（秒）
TRUTHCAST_URL_EXTRACT_LLM_TIMEOUT_SEC=20
# URL 评论抓取开关（仅影响站点特化评论提取）
TRUTHCAST_URL_COMMENT_ENABLED=true
# URL 评论最大抓取数量（尽可能多抓，但不超过该上限）
TRUTHCAST_URL_COMMENT_MAX_ITEMS=100

# 输入文本最大字符数（超出自动截断）
TRUTHCAST_MAX_INPUT_CHARS=8000

# LLM 并发限流：同时最多允许多少个 LLM 调用
TRUTHCAST_LLM_CONCURRENCY=5
# LLM 调用等待超时（秒）
TRUTHCAST_MAX_QUEUE_WAIT_SEC=30

# 内存缓存配置
# 风险快照缓存 TTL（秒）
TRUTHCAST_CACHE_DETECT_TTL=300
# 主张抽取缓存 TTL（秒）
TRUTHCAST_CACHE_CLAIMS_TTL=300
# 缓存最大条目数
TRUTHCAST_CACHE_MAX_SIZE=100

# 历史记录数据库路径（留空使用默认路径）
TRUTHCAST_HISTORY_DB_PATH=

# ------------------------------------------------------------
# 13. 应对内容生成配置
# ------------------------------------------------------------
# 是否启用 LLM 生成
TRUTHCAST_CONTENT_LLM_ENABLED=false

# LLM 模型配置（可独立配置，默认使用全局配置）
TRUTHCAST_CONTENT_LLM_MODEL=
TRUTHCAST_CONTENT_LLM_BASE_URL=
TRUTHCAST_CONTENT_LLM_API_KEY=

# 超时配置
TRUTHCAST_CONTENT_TIMEOUT_SEC=45

# 澄清稿配置
TRUTHCAST_CLARIFICATION_SHORT_MAX=150
TRUTHCAST_CLARIFICATION_MEDIUM_MAX=400
TRUTHCAST_CLARIFICATION_LONG_MAX=800

# FAQ 配置
TRUTHCAST_FAQ_DEFAULT_COUNT=5
TRUTHCAST_FAQ_MAX_COUNT=10

# 多平台话术配置
TRUTHCAST_PLATFORM_WEIBO_MAX=280
TRUTHCAST_PLATFORM_WECHAT_MAX=1000
TRUTHCAST_PLATFORM_XIAOHONGSHU_MAX=500
TRUTHCAST_PLATFORM_DOUYIN_MAX_SEC=60
TRUTHCAST_PLATFORM_KUAISHOU_MAX_SEC=90
TRUTHCAST_PLATFORM_BILIBILI_MAX_SEC=180

# Debug 配置
TRUTHCAST_DEBUG_CONTENT=true

# ============================================================
# 14. CLI 配置（命令行工具特有）
# ============================================================
# API 基础地址（优先级：CLI flag > TRUTHCAST_API_BASE > NEXT_PUBLIC_API_BASE > 默认值）
TRUTHCAST_API_BASE=http://127.0.0.1:8000


# CLI 请求超时时间（秒）
TRUTHCAST_CLI_TIMEOUT=30

# CLI 输出格式（text 或 json）
TRUTHCAST_CLI_OUTPUT_FORMAT=text

# CLI 请求重试次数
TRUTHCAST_CLI_RETRY_TIMES=3

# Chat 意图分类（LLM-first + 回退规则）
TRUTHCAST_CHAT_INTENT_LLM_ENABLED=false
TRUTHCAST_CHAT_INTENT_LLM_FIRST=true
TRUTHCAST_CHAT_INTENT_LLM_MODEL=
TRUTHCAST_CHAT_INTENT_LLM_BASE_URL=
TRUTHCAST_CHAT_INTENT_LLM_API_KEY=
TRUTHCAST_CHAT_INTENT_LLM_TIMEOUT_SEC=12

# Chat 会话成本与缓存护栏
TRUTHCAST_SESSION_TOOL_MAX_CALLS=50
TRUTHCAST_SESSION_LLM_MAX_CALLS=20
TRUTHCAST_SESSION_CACHE_TTL_SEC=300
TRUTHCAST_SESSION_HASH_BUCKET_LIMIT=8
# Chat SQLite 路径（留空使用默认）
TRUTHCAST_CHAT_DB_PATH=


# ------------------------------------------------------------
# 15. 多模态 OCR 配置
# ------------------------------------------------------------
TRUTHCAST_OCR_ENABLED=true
TRUTHCAST_OCR_PROVIDER=vision_llm
TRUTHCAST_OCR_FALLBACK_PROVIDER=paddleocr
TRUTHCAST_OCR_TIMEOUT_SEC=20
TRUTHCAST_OCR_MAX_RETRIES=1
TRUTHCAST_OCR_RETRY_DELAY=1
TRUTHCAST_OCR_CONFIDENCE_THRESHOLD=0.85
TRUTHCAST_OCR_FALLBACK_THRESHOLD=0.70
TRUTHCAST_DEBUG_OCR=true

# Vision-LLM OCR Provider（留空则回退全局 LLM 配置）
TRUTHCAST_OCR_LLM_ENABLED=true
TRUTHCAST_OCR_LLM_BASE_URL=
TRUTHCAST_OCR_LLM_API_KEY=
TRUTHCAST_OCR_LLM_MODEL=

# PaddleOCR 候选 Provider（建议以独立 HTTP 服务形式接入）
TRUTHCAST_PADDLEOCR_BASE_URL=http://127.0.0.1:9001
TRUTHCAST_PADDLEOCR_API_KEY=

# ------------------------------------------------------------
# 16. 多模态图片分析配置
# ------------------------------------------------------------
TRUTHCAST_VISION_ENABLED=true
TRUTHCAST_VISION_PROVIDER=vision_llm
TRUTHCAST_VISION_TIMEOUT_SEC=20
TRUTHCAST_VISION_MAX_RETRIES=1
TRUTHCAST_VISION_RETRY_DELAY=1
TRUTHCAST_DEBUG_VISION=true

# Vision Analysis Provider（留空则回退全局 LLM 配置）
TRUTHCAST_VISION_BASE_URL=
TRUTHCAST_VISION_API_KEY=
TRUTHCAST_VISION_MODEL=


# ------------------------------------------------------------
# 16. 多模态/网页抓取配置 (News Crawler)
# ------------------------------------------------------------
TRUTHCAST_CRAWLER_LLM_MODEL=
TRUTHCAST_CRAWLER_TIMEOUT_SEC=15  # 网页 HTTP 抓取超时（GET 原始页面）
TRUTHCAST_CRAWLER_LLM_TIMEOUT_SEC=45  # LLM 提取请求的基础超时（连接/发送等阶段）
TRUTHCAST_CRAWLER_LLM_READ_TIMEOUT_SEC=60  # LLM 提取请求的响应读取超时（等待模型返回内容）
TRUTHCAST_CRAWLER_LLM_MAX_RETRIES=2  # LLM 提取遇到超时时的最大尝试次数（含首次）
TRUTHCAST_CRAWLER_LLM_RETRY_DELAY_SEC=1  # LLM 提取超时后的重试间隔（秒）
TRUTHCAST_CRAWLER_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
TRUTHCAST_DEBUG_CRAWLER=true

# ------------------------------------------------------------
# 17. 实时监测与预警配置
# ------------------------------------------------------------
# 是否启用实时监测调度器（开启后按配置自动扫描、去重、落窗口，并可进入监测分析流程）
TRUTHCAST_MONITOR_ENABLED=false

# 监测数据库路径（留空使用默认 data/monitor/monitor.db）
TRUTHCAST_MONITOR_DB_PATH=

# MVP 默认用户 ID（监测订阅暂不支持多租户）
TRUTHCAST_MONITOR_DEFAULT_USER_ID=demo-user

# 监测平台配置文件（YAML）
TRUTHCAST_MONITOR_PLATFORM_CONFIG=config/monitor_platforms.yaml

# 仅启用指定平台（逗号分隔，留空则按 YAML enabled 生效）
TRUTHCAST_MONITOR_ENABLED_PLATFORMS=

# 按平台覆盖扫描周期（JSON 对象，如 {"thepaper":60,"zaobao":30}）
TRUTHCAST_MONITOR_PLATFORM_INTERVALS=

# NewsNow 查询接口地址
TRUTHCAST_NEWSNOW_BASE_URL=https://newsnow.busiyi.world/api/s

# 按平台覆盖 NewsNow ID（JSON 对象，如 {"thepaper":"thepaper","zaobao":"zaobao"}）
TRUTHCAST_NEWSNOW_PLATFORM_IDS=

# 说明：
# - 监测默认参数（scan_interval_minutes / fetch_top_n / risk_snapshot_threshold /
#   report_threshold_for_simulation）在 config/monitor_platforms.yaml 的 defaults 段配置
# - 优先级：平台配置值 > 全局默认值 > 代码内置默认值
# - 自动流程默认到“舆情预演”为止，应对内容生成需用户手动触发

# 监测运行控制参数
TRUTHCAST_MONITOR_SCAN_INTERVAL_MINUTES=10
TRUTHCAST_MONITOR_MANUAL_SCAN_AUTO_ANALYZE=false
# 同一热点的预警冷却时间（分钟）
TRUTHCAST_MONITOR_ALERT_COOLDOWN_MINUTES=30

# 通知渠道配置（可按订阅 notify_config 覆盖）
TRUTHCAST_MONITOR_WEBHOOK_URL=
TRUTHCAST_MONITOR_WECOM_WEBHOOK_URL=
TRUTHCAST_MONITOR_DINGTALK_WEBHOOK_URL=
TRUTHCAST_MONITOR_FEISHU_WEBHOOK_URL=

# 邮件通知配置
TRUTHCAST_MONITOR_SMTP_HOST=
TRUTHCAST_MONITOR_SMTP_PORT=587
TRUTHCAST_MONITOR_SMTP_USER=
TRUTHCAST_MONITOR_SMTP_PASSWORD=
TRUTHCAST_MONITOR_EMAIL_FROM=
TRUTHCAST_MONITOR_EMAIL_TO=
